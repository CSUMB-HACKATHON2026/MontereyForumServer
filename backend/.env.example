PORT=8080

SPRING_DATASOURCE_URL=jdbc:postgresql://your-host:5432/your-db?sslmode=require
SPRING_DATASOURCE_USERNAME=your-db-username
SPRING_DATASOURCE_PASSWORD=your-db-password

APP_AUTH_JWT_SECRET=replace-with-a-long-random-secret
APP_PUBLIC_ORIGIN=https://your-render-service.onrender.com

# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional app settings
APP_SECURITY_ADMIN_EMAILS=
APP_ANNOUNCEMENTS_CATEGORY_ID=1
